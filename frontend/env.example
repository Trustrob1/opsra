# Opsra Frontend — Environment Variables
# Copy this file to .env and fill in your values.
# NEVER commit .env to version control.

# Backend API base URL (no trailing slash)
# Development: http://localhost:8000
# Production:  https://your-render-backend.onrender.com
VITE_API_URL=http://localhost:8000

# Supabase anon key — used for frontend auth operations only.
# Do NOT use the service key here. The service key is backend-only.
VITE_SUPABASE_URL=https://your-project.supabase.co
VITE_SUPABASE_ANON_KEY=your-supabase-anon-key
